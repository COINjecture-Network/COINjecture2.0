# COINjecture Node — Environment Variables
# Copy this file to .env and fill in values before running docker-compose.
# Never commit .env to version control.

# ── Logging ──────────────────────────────────────────────────────────────────
# Rust log level: error | warn | info | debug | trace
RUST_LOG=info

# Set to 1 to enable full backtraces on panics (dev/staging only)
RUST_BACKTRACE=0

# ── Node Identity ─────────────────────────────────────────────────────────────
# 64-character hex address used as the mining reward recipient.
# Generate with: openssl rand -hex 32
MINER_ADDRESS=

# ── HuggingFace Integration ───────────────────────────────────────────────────
# API token for uploading problem datasets to HuggingFace Hub.
# Required only when --hf-token flag is used.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Network ───────────────────────────────────────────────────────────────────
# Comma-separated CPP peer addresses (host:port) to dial on startup.
# Without this, the node runs standalone (0 peers). Port is CPP P2P (default 707).
# COINJECT_BOOTNODES is preferred; BOOTNODES is an alias for the same list.
# Example: COINJECT_BOOTNODES=203.0.113.10:707,203.0.113.11:707
COINJECT_BOOTNODES=
BOOTNODES=

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute path on the host to persist chain data outside of a Docker volume.
# Leave empty to use named Docker volumes (recommended for production).
DATA_DIR=

# ── Difficulty ────────────────────────────────────────────────────────────────
# Initial mining difficulty (number of leading zero bits required).
# Testnet default: 4  |  Production: set higher after genesis
DIFFICULTY=4

# ── JSON-RPC (node) ───────────────────────────────────────────────────────────
# Max HTTP body for RPC (bytes). Default in code is 1 MiB — too small for chain_submitBlock via API proxy.
# 67108864 = 64 MiB (aligned with api-server DefaultBodyLimit).
RPC_MAX_BODY_BYTES=67108864
# Per-request timeout for RPC HTTP layer (seconds). Large block submit / validation may need 300+.
RPC_TIMEOUT_SECS=300

# ── Faucet (testnet only) ─────────────────────────────────────────────────────
# Amount of base units to dispense per faucet request.
FAUCET_AMOUNT=10000
