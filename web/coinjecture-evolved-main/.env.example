# RPC Endpoint URL
# For local development: http://localhost:9933
# For production: https://your-node-domain.com:9933
# For CloudFront: Use your CloudFront distribution domain or API Gateway endpoint
VITE_RPC_URL=http://localhost:9933

# Optional: Metrics endpoint (if separate from RPC)
VITE_METRICS_URL=http://localhost:9094

# API server (SIWB auth, marketplace, etc.)
VITE_API_URL=http://localhost:3030

# Supabase (optional — email auth requires these)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
