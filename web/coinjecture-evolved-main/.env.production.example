# Loaded automatically by `vite build` / `npm run build` (not committed).
# Copy to `.env.production` before deploying the static site.

# Required: auth, GET /chain/info, and (by default) browser JSON-RPC via POST /node-rpc on this host
# (API forwards to NODE_RPC_URL — no http://localhost:9933 in the static bundle).
VITE_API_URL=https://api.coinjecture.com

# Optional: comma-separated HTTPS public RPC URLs for multi-node / direct RPC. If unset, the app uses
# VITE_API_URL + /node-rpc. If you set http:// or localhost here, production HTTPS builds still use /node-rpc.
# VITE_RPC_URL=https://rpc1.coinjecture.com
